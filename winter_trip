<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@600;800&family=IBM+Plex+Sans:wght@400;500;600&family=Noto+Sans+SC:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--night:#101D33;--night2:#1B2E4D;--snow:#F3F7FA;--card:#FFF;--ice:#2E8FB8;--ice-soft:#E3F1F7;--lantern:#E39A3B;--lantern-soft:#FBEFDC;--ink:#1C2940;--mut:#5D6B82;--line:#DCE5EE;--pine:#2F6B57;--pine-soft:#E2F0EA}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html{scroll-behavior:smooth}
body{background:var(--snow);color:var(--ink);font-family:'IBM Plex Sans','Noto Sans SC',sans-serif;font-size:15px;line-height:1.55}
.wrap{max-width:760px;margin:0 auto;padding:0 14px 80px}
header{background:linear-gradient(168deg,var(--night) 0%,var(--night2) 62%,#27436B 100%);color:#EAF2FB;position:relative;overflow:hidden;padding:34px 18px 40px;text-align:center}
header h1{font-family:'Shippori Mincho',serif;font-weight:800;font-size:30px;letter-spacing:.5px}
header .jp{font-family:'Shippori Mincho',serif;font-size:15px;color:#9FB6D6;margin-top:4px;letter-spacing:6px}
header .meta{margin-top:12px;font-size:12.5px;color:#BCD0E8;display:flex;gap:14px;justify-content:center;flex-wrap:wrap}
header .meta b{color:#fff;font-weight:600}
.flake{position:absolute;top:-12px;color:#fff;opacity:.55;font-size:11px;animation:fall linear infinite;pointer-events:none}
@keyframes fall{to{transform:translateY(112vh) translateX(24px)}}
@media (prefers-reduced-motion:reduce){.flake{display:none}}
.sunset-band{background:var(--lantern);color:#3C2A0C;font-size:12.5px;font-weight:600;text-align:center;padding:7px 12px}
nav{position:sticky;top:0;z-index:50;background:var(--night);padding:10px 0 12px;box-shadow:0 4px 14px rgba(16,29,51,.28)}
.rail{display:flex;overflow-x:auto;scrollbar-width:none;padding:6px 14px 2px;align-items:flex-start}
.rail::-webkit-scrollbar{display:none}
.stopbtn{flex:0 0 auto;text-decoration:none;color:#8FA6C6;text-align:center;padding:0 9px;position:relative;display:block}
.stopbtn .dot{display:block;width:12px;height:12px;border-radius:50%;background:#37507A;border:2px solid #58749F;margin:0 auto 5px;transition:.2s}
.stopbtn::before{content:'';position:absolute;top:6px;left:-50%;width:100%;height:2px;background:#37507A}
.stopbtn:first-child::before{display:none}
.stopbtn .d{display:block;font-size:10px;letter-spacing:.4px}
.stopbtn .n{display:block;font-size:11.5px;font-weight:600;white-space:nowrap;color:#C6D6EC}
.stopbtn.active .dot,.stopbtn:hover .dot{background:var(--lantern);border-color:#F6C87E;box-shadow:0 0 10px rgba(227,154,59,.8)}
.stopbtn.active .n{color:#fff}
.daysec{padding-top:8px;margin-top:6px}
.daysec:not(:first-of-type){border-top:2px dashed var(--line);margin-top:30px;padding-top:18px}
.dayhead{margin:14px 2px 14px}
.dayhead .eyebrow{font-size:11.5px;letter-spacing:2px;text-transform:uppercase;color:var(--ice);font-weight:600}
.dayhead h2{font-family:'Shippori Mincho',serif;font-size:24px;font-weight:800;margin-top:2px}
.dayhead .cn{color:var(--mut);font-size:14px;margin-top:1px}
.chips{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px}
.chip{font-size:11.5px;font-weight:600;padding:4px 10px;border-radius:20px;background:var(--ice-soft);color:#20618A}
.chip.warn{background:var(--lantern-soft);color:#8A5A14}
.chip.night{background:var(--night);color:#F4CE8F}
.hotel{background:var(--night);color:#E8F0FA;border-radius:14px;padding:14px 16px;margin:0 0 18px;display:flex;gap:12px;align-items:flex-start}
.hotel .ic{font-size:20px;margin-top:2px}
.hotel b{font-weight:600;color:#fff}
.hotel .sub{font-size:12.5px;color:#A9BFDC;margin-top:2px}
.hotel a{color:var(--lantern);text-decoration:none;font-size:12.5px;font-weight:600}
.tl{position:relative;padding-left:64px}
.tl::before{content:'';position:absolute;left:46px;top:8px;bottom:8px;width:2px;background:var(--line)}
.stop{position:relative;margin-bottom:14px}
.stop .time{position:absolute;left:-64px;top:14px;width:40px;text-align:right;font-size:12px;font-weight:600;color:var(--mut)}
.stop::before{content:'';position:absolute;left:-23px;top:18px;width:10px;height:10px;border-radius:50%;background:var(--ice);border:2px solid #fff;box-shadow:0 0 0 2px var(--ice)}
.stop.onsen::before{background:var(--lantern);box-shadow:0 0 0 2px var(--lantern)}
.stop.night::before{background:var(--night);box-shadow:0 0 0 2px var(--night)}
.card{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:13px 14px;box-shadow:0 1px 4px rgba(28,41,64,.05)}
.card h3{font-size:15.5px;font-weight:600;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.card .names{font-size:13px;color:var(--mut);margin-top:1px}
.badge{font-size:10px;font-weight:700;letter-spacing:.5px;padding:2px 7px;border-radius:10px;vertical-align:middle}
.badge.hot{background:#FDE8E8;color:#C0392B}
.badge.eat{background:var(--pine-soft);color:var(--pine)}
.badge.onsenb{background:var(--lantern-soft);color:#8A5A14}
.badge.nightb{background:var(--night);color:#F4CE8F}
.note{font-size:13.5px;color:#3C4B63;margin-top:7px}
.links{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px}
.links a{display:inline-flex;align-items:center;gap:4px;font-size:12px;font-weight:600;text-decoration:none;padding:6px 11px;border-radius:20px;border:1px solid var(--line);color:var(--ink);background:#FAFCFE}
.links a.map{background:var(--ice);border-color:var(--ice);color:#fff}
.links a.xhs{color:#D0342C;border-color:#F2C9C6}
.links a.ig{color:#B03A8E;border-color:#EBC9E1}
.links a.yt{color:#8A2020;border-color:#E8CFCF}
.tipbox{background:var(--lantern-soft);border:1px solid #F0DDBC;border-radius:14px;padding:13px 15px;font-size:13.5px;margin:16px 0;color:#5A400F}
.tipbox b{color:#3C2A0C}
.checklist{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:14px 16px;margin:14px 0}
.checklist h3{font-family:'Shippori Mincho',serif;font-size:17px;margin-bottom:8px}
.checklist li{margin:6px 0 6px 18px;font-size:13.5px}
/* tab mode — applied by JS only; without JS the page stays fully scrollable */
body.tabbed .daysec{display:none}
body.tabbed .daysec.show{display:block;animation:fade .25s ease;border-top:none;margin-top:6px;padding-top:8px}
@keyframes fade{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.top{position:fixed;right:14px;bottom:18px;background:var(--night);color:#F4CE8F;text-decoration:none;border-radius:24px;padding:10px 14px;font-size:12.5px;font-weight:600;box-shadow:0 4px 14px rgba(16,29,51,.35);z-index:60}
footer{text-align:center;color:var(--mut);font-size:12px;margin-top:36px}
</style>
</head>
