<script>
/* progressive enhancement only — page fully works without this */
try{
  if(!window.matchMedia('(prefers-reduced-motion: reduce)').matches){
    var hero=document.getElementById('hero');
    for(var i=0;i<26;i++){var f=document.createElement('span');f.className='flake';f.textContent='❄';f.style.left=Math.random()*100+'%';f.style.animationDuration=(6+Math.random()*9)+'s';f.style.animationDelay=(-Math.random()*10)+'s';f.style.fontSize=(7+Math.random()*8)+'px';hero.appendChild(f);}
  }
  var links=[].slice.call(document.querySelectorAll('.stopbtn'));
  var secs=[].slice.call(document.querySelectorAll('.daysec'));

  /* click-to-view day-by-day: activates ONLY if this script runs.
     Fallback: plain anchor links scroll to the day. */
  document.body.classList.add('tabbed');
  function openDay(id,push){
    var found=false;
    secs.forEach(function(s){var on=(s.id===id);s.classList.toggle('show',on);if(on)found=true;});
    if(!found&&secs[0]){secs[0].classList.add('show');id=secs[0].id;}
    links.forEach(function(l){l.classList.toggle('active',l.getAttribute('href')==='#'+id);});
    if(push&&history.replaceState)history.replaceState(null,'','#'+id);
    window.scrollTo(0,0);
  }
  links.forEach(function(l){
    l.addEventListener('click',function(ev){
      ev.preventDefault();
      openDay(l.getAttribute('href').slice(1),true);
    });
  });
  window.addEventListener('hashchange',function(){var h=location.hash.slice(1);if(h.indexOf('day')===0)openDay(h,false);});
  var h0=location.hash.slice(1);
  openDay(h0.indexOf('day')===0?h0:'day0',false);

  if('IntersectionObserver' in window){
    var io=new IntersectionObserver(function(es){es.forEach(function(e){if(e.isIntersecting){links.forEach(function(l){l.classList.toggle('active',l.getAttribute('href')==='#'+e.target.id);});}});},{rootMargin:'-40% 0px -55% 0px'});
    secs.forEach(function(s){io.observe(s);});
  }
}catch(e){}
</script>
